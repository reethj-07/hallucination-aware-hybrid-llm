# -- RAG Behavior -------------------------------------------------
RAG_LIGHTWEIGHT=true              # true=fast template mode, false=Phi-3 LLM
RAG_RERANK=false                  # Enable cross-encoder reranking (slower, more accurate)
RAG_SKIP_CHUNKING=false           # false=proper chunking (recommended), true=legacy full-doc mode
RAG_MAX_CONTEXT_CHARS=4000        # Max chars fed to LLM context window
RAG_TOP_K=5                       # Number of retrieved chunks
RAG_INDEX_PATH=rag/faiss_index/index.faiss
RAG_DOCS_PATH=rag/faiss_index/docs.pkl

# -- Hallucination Guard -----------------------------------------
FAITHFULNESS_THRESHOLD=0.4        # NLI entailment score below which answer is abstained
USE_NLI_GUARD=true                # true=NLI faithfulness, false=token overlap fallback

# -- API & Server -------------------------------------------------
REQUEST_TIMEOUT_S=20
API_KEY=                          # Leave blank to disable auth
RATE_LIMIT=60/minute
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO
PORT=8000

# -- Models -------------------------------------------------------
RAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
NLI_MODEL=cross-encoder/nli-deberta-v3-small
BASE_MODEL_ID=microsoft/Phi-3-mini-4k-instruct
LORA_PATH=models/phi3_lora_final

# -- Experiment Tracking -----------------------------------------
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=rag-evals
